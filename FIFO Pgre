#include <stdio.h>
#include <stdlib.h>

int main() {
    int pages[50], frames[10];
    int n, f, i, j, k;
    int flag, faults = 0;

    printf("Enter number of pages: ");
    scanf("%d", &n);

    printf("Enter page reference string:\n");
    for (i = 0; i < n; i++) {
        scanf("%d", &pages[i]);
    }

    printf("Enter number of frames: ");
    scanf("%d", &f);

    // Initialize frames with -1 (empty)
    for (i = 0; i < f; i++) {
        frames[i] = -1;
    }

    printf("\n=== FIFO Page Replacement ===\n");
    printf("Page Frames:\n");

    int index = 0;  // Pointer to the frame to be replaced

    // Process each page
    for (i = 0; i < n; i++) {
        flag = 0;

        // Check if page is already in frame
        for (j = 0; j < f; j++) {
            if (frames[j] == pages[i]) {
                flag = 1;
                break;
            }
        }

        // If page is not in frame (page fault)
        if (flag == 0) {
            frames[index] = pages[i];
            index = (index + 1) % f;  // Move to next frame position
            faults++;
        }

        // Display current frames
        printf("Page %d: ", pages[i]);
        for (j = 0; j < f; j++) {
            if (frames[j] == -1) {
                printf("- ");
            } else {
                printf("%d ", frames[j]);
            }
        }

        if (flag == 0) {
            printf("(Page Fault)");
        }

        printf("\n");
    }

    printf("\nTotal Page Faults: %d\n", faults);
    printf("Total Page Hits: %d\n", n - faults);
    printf("Page Hit Ratio: %.2f%%\n",
           ((float)(n - faults) / n) * 100);

    return 0;
}
